# Port the API server listens on
PORT=3001

# Allowed CORS origin (the URL users access the frontend from)
# Local dev:
CLIENT_ORIGIN=http://localhost:5173
# Server deployment (if frontend and backend are on same host, port 3000):
# CLIENT_ORIGIN=http://your-server.example.com:3000

# Public base URL of this API, used to generate the JWKS URL shown in the UI.
# Set this in server/reverse-proxy deployments.
# PUBLIC_API_URL=https://your-server.example.com
