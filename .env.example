# ── Docker Compose environment variables ──────────────────────────────────────
# Copy this file to .env and adjust for your deployment.

# Port the API server listens on (inside container and mapped to host)
SERVER_PORT=3001

# Port the frontend is served on (mapped to host)
CLIENT_PORT=5173

# Allowed CORS origin — must match the URL users open in their browser
# Local dev:
CLIENT_ORIGIN=http://localhost:5173
# Server deployment example:
# CLIENT_ORIGIN=http://your-server.example.com:3000

# Backend API URL — must be reachable from the user's browser
# Local dev:
VITE_API_URL=http://localhost:3001
# Server deployment example:
# VITE_API_URL=http://your-server.example.com:3001

# Public base URL of the API — used to build the JWKS URL shown in the UI.
# Must match what the auth server can reach to fetch the JWKS.
# Server deployment example:
# PUBLIC_API_URL=http://your-server.example.com:3001
